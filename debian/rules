#!/usr/bin/make -f

export DEB_BUILD_MAINT_OPTIONS = hardening=+all
export DH_VERBOSE = 1
export GO111MODULE=on

include /usr/share/dpkg/architecture.mk

ifeq ($(DEB_TARGET_ARCH_CPU),amd64)
    GO_ARCH = amd64
else ifeq ($(DEB_TARGET_ARCH_CPU),arm64)
    GO_ARCH = arm64
else
    GO_ARCH = $(DEB_TARGET_ARCH_CPU)
endif

%:
	dh $@ --builddirectory=build

override_dh_auto_build:
	mkdir -p bin
	GOOS=linux GOARCH=$(GO_ARCH) GOFLAGS="" \
	go build -trimpath -o bin/local-proxy ./cmd/local_proxy

override_dh_auto_install:
	install -D -m0755 bin/local-proxy $(CURDIR)/debian/local-proxy/usr/bin/local-proxy

override_dh_dwz:
	@echo "Skipping dh_dwz for Go binary"

override_dh_fixperms:
	dh_fixperms
	if [ -d $(CURDIR)/debian/local-proxy/usr/lib/local-proxy/scripts ]; then \
		chmod +x $(CURDIR)/debian/local-proxy/usr/lib/local-proxy/scripts/*.sh; \
	fi